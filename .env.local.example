# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# --- Database ---
# MongoDB Atlas (or any Mongo-compatible) connection string.
MONGODB_URI=

# --- Auth ---
# Long random strings. Generate with: openssl rand -hex 32
JWT_SECRET=
REFRESH_TOKEN_SECRET=

# --- SnapTrade (brokerage connections) ---
# Get these from https://dashboard.snaptrade.com after creating a partner account.
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# Encryption key for the userSecret field in the database.
# Must be a 64-character hex string (32 bytes). Generate with: openssl rand -hex 32
# Required in production. If this is missing, the app will refuse to start.
USER_SECRET_ENCRYPTION_KEY=

# --- Massive (market data) ---
# API key for the Massive REST API.
MASSIVE_API_KEY=
# Optional override for the Massive REST API base URL. Defaults to https://api.massive.com.
MASSIVE_API_BASE=

# --- App config ---
# Public base URL the app is served from. In production this MUST match the
# deployed URL, otherwise SnapTrade OAuth redirects will bounce users back to
# http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Benchmark ticker used for CAPM beta / alpha calculations.
BENCHMARK_SYMBOL=SPY

# Node environment. Usually "development" locally, "production" when deployed.
NODE_ENV=development
